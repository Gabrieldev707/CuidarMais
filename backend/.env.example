# Porta (Railway injeta PORT automaticamente; localmente usa 5000)
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:senha@cluster0.xxxx.mongodb.net/cuidarmais?retryWrites=true&w=majority

# JWT
JWT_SECRET=troque_por_um_segredo_forte
JWT_EXPIRES_IN=90d

# Email (Gmail App Password) — usado para convites de gestor
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua_app_password_do_gmail

# URL do frontend em produção (para liberar no CORS). Ex.: https://cuidarmais.vercel.app
FRONTEND_URL=
