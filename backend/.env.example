# Porta (Railway injeta PORT automaticamente; localmente usa 5000)
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:senha@cluster0.xxxx.mongodb.net/cuidarmais?retryWrites=true&w=majority

# JWT
JWT_SECRET=troque_por_um_segredo_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=90d

# Email (Gmail App Password) — usado para convites de gestor
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua_app_password_do_gmail
EMAIL_FROM="CuidarMais <seu-email@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Mantenha true em producao. Use false localmente apenas se a maquina interceptar certificados TLS.
SMTP_REJECT_UNAUTHORIZED=true

# URLs exatas do frontend. Multiplas origens podem ser separadas por virgula.
FRONTEND_URL=http://localhost:5174
# Opcional: regex separados por virgula para origens adicionais.
# CORS_ALLOWED_PATTERNS=^https://frontend-[a-z0-9-]+\\.vercel\\.app$
